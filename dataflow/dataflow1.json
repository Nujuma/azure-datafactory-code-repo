{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DelimitedText1",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "surrogateKey1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "cast1"
				},
				{
					"name": "rank1"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"parameters{",
				"     partitionparam as integer (2)",
				"}",
				"source(output(",
				"          cid as integer,",
				"          custid as integer,",
				"          call_dur as integer,",
				"          cost as double,",
				"          insertdt as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     enableCdc: true,",
				"     mode: 'read',",
				"     skipInitialLoad: false,",
				"     waterMarkColumn: 'cid',",
				"     batchSize: 2,",
				"     isolationLevel: 'READ_COMMITTED',",
				"     query: 'select * from izdb.cdr',",
				"     format: 'query',",
				"     partitionBy('roundRobin', ($partitionparam))) ~> source1",
				"filter1 select(mapColumn(",
				"          cid,",
				"          customerid = custid,",
				"          call_dur,",
				"          cost,",
				"          insertdt",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(loaddt = currentDate()) ~> derivedColumn1",
				"derivedColumn1 keyGenerate(output(seqnosk as long),",
				"     startAt: 1L,",
				"     stepValue: 1L,",
				"     partitionBy('roundRobin', 2)) ~> surrogateKey1",
				"source1 filter(greaterOrEqual(call_dur,401)) ~> filter1",
				"surrogateKey1 cast(output(",
				"          customerid as string",
				"     ),",
				"     errors: true) ~> cast1",
				"filter1 rank(desc(call_dur, true),",
				"     caseInsensitive: true,",
				"     output(custid_rnk as long)) ~> rank1",
				"rank1 aggregate(groupBy(custid,",
				"          custid_rnk),",
				"     avg_call_dur = avg(call_dur),",
				"          sum_cost = sum(cost)) ~> aggregate1",
				"aggregate1 alterRow(deleteIf(lesserOrEqual(sum_cost,5))) ~> alterRow1",
				"cast1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     preCommands: [],",
				"     postCommands: []) ~> sink1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     format: 'table') ~> sink2"
			]
		}
	}
}